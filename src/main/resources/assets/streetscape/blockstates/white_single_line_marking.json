{
  "multipart": [
    {
      "apply": {
        "model": "streetscape:block/asphalt_base"
      }
    },
    {
      "when": {
        "north": "false",
        "east": "false",
        "south": "false",
        "west": "false"
      },
      "apply": {
        "model": "streetscape:block/white_dot_overlay"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "streetscape:block/white_line_overlay"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "streetscape:block/white_line_overlay",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "streetscape:block/white_line_overlay",
        "y": 180
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "streetscape:block/white_line_overlay",
        "y": 270
      }
    }
  ]
}
